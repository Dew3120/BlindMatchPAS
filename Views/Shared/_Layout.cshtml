<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #FAFAF8;
            color: #2C2A26;
        }
        main {
            flex: 1;
        }
        .nav-link-custom {
            color: #9CA3B4;
            text-decoration: none;
            font-size: 14px;
            padding: 6px 14px;
            border-radius: 6px;
            transition: all 0.3s ease;
            position: relative;
        }
        .nav-link-custom:hover {
            color: #C9A96E;
            background: rgba(201, 169, 110, 0.1);
            transform: translateY(-1px);
        }
        .nav-link-custom::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: #C9A96E;
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }
        .nav-link-custom:hover::after {
            width: 70%;
        }
        .brand-logo {
            transition: all 0.3s ease;
        }
        .brand-logo:hover {
            transform: scale(1.05);
        }
        .brand-logo:hover .brand-icon {
            box-shadow: 0 0 12px rgba(201, 169, 110, 0.4);
        }
        .avatar-circle {
            transition: all 0.3s ease;
        }
        .avatar-circle:hover {
            transform: scale(1.1);
            box-shadow: 0 0 10px rgba(201, 169, 110, 0.3);
        }
        .logout-btn {
            background: none;
            border: none;
            color: #9CA3B4;
            font-size: 13px;
            cursor: pointer;
            padding: 4px 10px;
            border-radius: 4px;
            transition: all 0.3s ease;
        }
        .logout-btn:hover {
            color: #C9A96E;
            background: rgba(201, 169, 110, 0.1);
        }
        .login-link {
            color: #C9A96E;
            text-decoration: none;
            font-size: 14px;
            padding: 8px 20px;
            border: 1px solid #C9A96E;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .login-link:hover {
            background: #C9A96E;
            color: #1A1F36;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(201, 169, 110, 0.3);
        }
        footer {
            background-color: #0F1225;
            padding: 24px;
            text-align: center;
            margin-top: auto;
        }
        footer p {
            color: #8A8578;
            font-size: 13px;
            margin: 0;
            letter-spacing: 0.5px;
        }
        .navbar-main {
            background-color: #1A1F36;
            padding: 12px 24px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
    </style>
</head>
<body>

    <nav class="navbar custom-navbar navbar-expand-lg">
    <div class="container mt-4">
    <div class="row">
        <div class="col-md-6 col-sm-12">
        </div>
    </div>
</div>
<div class="card p-3 shadow-sm">
    <h5>Title</h5>
    <p class="text-muted">Description</p>
</div>

    <a class="navbar-brand text-gold" href="/">BlindMatchPAS</a>

    <ul class="navbar-nav me-auto">

        @if (User.IsInRole("Student"))
        {
            <li><a class="nav-link" asp-controller="Student" asp-action="Dashboard">Student</a></li>
        }

        @if (User.IsInRole("Supervisor"))
        {
            <li><a class="nav-link" asp-controller="Supervisor" asp-action="Dashboard">Supervisor</a></li>
        }

        @if (User.IsInRole("ModuleLeader"))
        {
            <li><a class="nav-link" asp-controller="ModuleLeader" asp-action="Index">Module Leader</a></li>
        }

        @if (User.IsInRole("Admin"))
        {
            <li><a class="nav-link" asp-controller="Admin" asp-action="Index">Admin</a></li>
        }

    </ul>

</nav>

    <main class="container mt-4 mb-5">
        @RenderBody()
    </main>

    <footer>
        <p>Blind-Match PAS &copy; 2026 — Project Approval System</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>