<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background-color: #FAFAF8; color: #2C2A26;">

    <nav style="background-color: #1A1F36; padding: 12px 24px;">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 10px;">
                <div style="width: 32px; height: 32px; background: #C9A96E; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                    <span style="color: #1A1F36; font-weight: bold; font-size: 16px;">B</span>
                </div>
                <span style="color: #C9A96E; font-size: 18px; font-weight: 600; letter-spacing: 0.3px;">Blind-Match PAS</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" style="color: #9CA3B4; text-decoration: none; font-size: 14px;">Admin Panel</a>
                    }
                    @if (User.IsInRole("ModuleLeader"))
                    {
                        <a asp-controller="ModuleLeader" asp-action="Index" style="color: #9CA3B4; text-decoration: none; font-size: 14px;">Dashboard</a>
                    }
                    @if (User.IsInRole("Supervisor"))
                    {
                        <a asp-controller="Supervisor" asp-action="Dashboard" style="color: #9CA3B4; text-decoration: none; font-size: 14px;">Dashboard</a>
                        <a asp-controller="Supervisor" asp-action="MyExpertise" style="color: #9CA3B4; text-decoration: none; font-size: 14px;">My Expertise</a>
                        <a asp-controller="Supervisor" asp-action="MyMatches" style="color: #9CA3B4; text-decoration: none; font-size: 14px;">My Matches</a>
                    }
                    @if (User.IsInRole("Student"))
                    {
                        <a asp-controller="Student" asp-action="Dashboard" style="color: #9CA3B4; text-decoration: none; font-size: 14px;">Dashboard</a>
                    }
                    <div style="display: flex; align-items: center; gap: 8px; margin-left: 16px;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: #2D3555; display: flex; align-items: center; justify-content: center; color: #C9A96E; font-size: 12px; font-weight: 600;">
                            @User.Identity.Name?.Substring(0, 1).ToUpper()
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0;">
                            <button type="submit" style="background: none; border: none; color: #9CA3B4; font-size: 13px; cursor: pointer;">Logout</button>
                        </form>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" style="color: #C9A96E; text-decoration: none; font-size: 14px;">Login</a>
                }
            </div>
        </div>
    </nav>

    <main class="container mt-4 mb-5">
        @RenderBody()
    </main>

    <footer style="background-color: #0F1225; padding: 20px; text-align: center;">
        <p style="color: #8A8578; font-size: 13px; margin: 0;">Blind-Match PAS &copy; 2026 — Project Approval System</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>