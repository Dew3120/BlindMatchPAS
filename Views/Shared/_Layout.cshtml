<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #FAFAF8;
            color: #2C2A26;
        }
        main {
            flex: 1;
        }
        .nav-link-custom {
            color: #9CA3B4;
            text-decoration: none;
            font-size: 14px;
            padding: 6px 14px;
            border-radius: 6px;
            transition: all 0.3s ease;
            position: relative;
        }
        .nav-link-custom:hover {
            color: #C9A96E;
            background: rgba(201, 169, 110, 0.1);
            transform: translateY(-1px);
        }
        .nav-link-custom::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: #C9A96E;
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }
        .nav-link-custom:hover::after {
            width: 70%;
        }
        .brand-logo {
            transition: all 0.3s ease;
        }
        .brand-logo:hover {
            transform: scale(1.05);
        }
        .brand-logo:hover .brand-icon {
            box-shadow: 0 0 12px rgba(201, 169, 110, 0.4);
        }
        .avatar-circle {
            transition: all 0.3s ease;
        }
        .avatar-circle:hover {
            transform: scale(1.1);
            box-shadow: 0 0 10px rgba(201, 169, 110, 0.3);
        }
        .logout-btn {
            background: none;
            border: none;
            color: #9CA3B4;
            font-size: 13px;
            cursor: pointer;
            padding: 4px 10px;
            border-radius: 4px;
            transition: all 0.3s ease;
        }
        .logout-btn:hover {
            color: #C9A96E;
            background: rgba(201, 169, 110, 0.1);
        }
        .login-link {
            color: #C9A96E;
            text-decoration: none;
            font-size: 14px;
            padding: 8px 20px;
            border: 1px solid #C9A96E;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .login-link:hover {
            background: #C9A96E;
            color: #1A1F36;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(201, 169, 110, 0.3);
        }
        footer {
            background-color: #0F1225;
            padding: 24px;
            text-align: center;
            margin-top: auto;
        }
        footer p {
            color: #8A8578;
            font-size: 13px;
            margin: 0;
            letter-spacing: 0.5px;
        }
        .navbar-main {
            background-color: #1A1F36;
            padding: 12px 24px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
    </style>
</head>
<body>

    <nav class="navbar-main">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <a href="/" class="brand-logo" style="text-decoration: none; display: flex; align-items: center; gap: 10px;">
                <div class="brand-icon" style="width: 34px; height: 34px; background: linear-gradient(135deg, #C9A96E, #E8D5B5); border-radius: 8px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;">
                    <span style="color: #1A1F36; font-weight: bold; font-size: 17px;">B</span>
                </div>
                <span style="color: #C9A96E; font-size: 18px; font-weight: 600; letter-spacing: 0.5px;">Blind-Match PAS</span>
            </a>

            <div class="d-flex align-items-center gap-2">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="nav-link-custom">Admin Panel</a>
                    }
                    @if (User.IsInRole("ModuleLeader"))
                    {
                        <a asp-controller="ModuleLeader" asp-action="Index" class="nav-link-custom">Dashboard</a>
                    }
                    @if (User.IsInRole("Supervisor"))
                    {
                        <a asp-controller="Supervisor" asp-action="Dashboard" class="nav-link-custom">Dashboard</a>
                        <a asp-controller="Supervisor" asp-action="MyExpertise" class="nav-link-custom">My Expertise</a>
                        <a asp-controller="Supervisor" asp-action="MyMatches" class="nav-link-custom">My Matches</a>
                    }
                    @if (User.IsInRole("Student"))
                    {
                        <a asp-controller="Student" asp-action="Dashboard" class="nav-link-custom">Dashboard</a>
                    }

                    <div style="display: flex; align-items: center; gap: 8px; margin-left: 16px;">
                        <div class="avatar-circle" style="width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, #2D3555, #1A1F36); border: 2px solid #C9A96E; display: flex; align-items: center; justify-content: center; color: #C9A96E; font-size: 13px; font-weight: 600;">
                            @User.Identity.Name?.Substring(0, 1).ToUpper()
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0;">
                            <button type="submit" class="logout-btn">Logout</button>
                        </form>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="login-link">Login</a>
                }
            </div>
        </div>
    </nav>

    <main class="container mt-4 mb-5">
        @RenderBody()
    </main>

    <footer>
        <p>Blind-Match PAS &copy; 2026 — Project Approval System</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>