@model IEnumerable<BlindMatchPAS.Models.Match>

@{
    ViewData["Title"] = "My Matches";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Match Status</h2>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-light border border-secondary shadow-sm">
            <i class="bi bi-info-circle me-2"></i> You have not expressed interest in any projects yet.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var match in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm @(match.Status == BlindMatchPAS.Models.Enums.MatchStatus.Confirmed ? "border-success" : "border-warning")">
                        <div class="card-header @(match.Status == BlindMatchPAS.Models.Enums.MatchStatus.Confirmed ? "bg-success text-white" : "bg-warning text-dark") fw-bold">
                            Match Status: @match.Status.ToString()
                        </div>
                        
                        <div class="card-body">
                            <h5 class="card-title">@match.ProjectProposal.Title</h5>
                            <hr />
                            
                            @if (match.Status == BlindMatchPAS.Models.Enums.MatchStatus.Confirmed)
                            {
                                <div class="bg-light p-3 rounded mt-3 border border-success">
                                    <h6 class="text-success"><i class="bi bi-unlock-fill"></i> Identity Revealed</h6>
                                    <p class="mb-1"><strong>Student Name:</strong> @match.ProjectProposal.SubmittedBy.FullName</p>
                                    <p class="mb-0"><strong>Contact:</strong> @match.ProjectProposal.SubmittedBy.Email</p>
                                </div>
                            }
                            else
                            {
                                <div class="bg-light p-3 rounded mt-3 border border-warning">
                                    <h6 class="text-warning"><i class="bi bi-lock-fill"></i> Identity Hidden</h6>
                                    <p class="text-muted mb-0">Student details will be revealed once the match is finalized by the administration.</p>
                                </div>
                            }
                        </div>

                        @if (match.Status == BlindMatchPAS.Models.Enums.MatchStatus.Interested)
                        {
                            <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                                <form asp-action="ConfirmMatch" method="post">
                                    <input type="hidden" name="matchId" value="@match.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Confirm Match</button>
                                </form>
                                <form asp-action="RejectMatch" method="post">
                                    <input type="hidden" name="matchId" value="@match.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Withdraw Interest</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>