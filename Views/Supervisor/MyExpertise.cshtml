@model List<BlindMatchPAS.Models.ViewModels.ExpertiseViewModel>

@{
    ViewData["Title"] = "My Expertise Areas";
}

<div class="row justify-content-center">
    <div class="col-md-8">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="background: #E8F5ED; border: 1px solid #2D8A5E; color: #1B5E3F;">
                @TempData["Success"]
            </div>
        }

        <div style="background: #F4F3F0; border-radius: 12px; padding: 24px; border: 0.5px solid #E0DDD6; margin-bottom: 24px;">
            <h4 style="color: #1A1F36; font-weight: 600; margin-bottom: 4px;">Select your expertise areas</h4>
            <p style="color: #8A8578; font-size: 14px; margin-bottom: 0;">Choose research areas that match your expertise. You will only see project proposals from these areas.</p>
        </div>

        <form asp-action="MyExpertise" method="post">
            @Html.AntiForgeryToken()

            <div style="display: flex; flex-direction: column; gap: 12px;">
                @foreach (var area in Model)
                {
                    <label style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: #FAFAF8; border-radius: 10px; border: 0.5px solid @(area.IsSelected ? "#C9A96E" : "#E0DDD6"); cursor: pointer;">
                        <input type="checkbox"
                               name="selectedAreas"
                               value="@area.ResearchAreaId"
                               @(area.IsSelected ? "checked" : "")
                               style="width: 18px; height: 18px; accent-color: #C9A96E;" />
                        <span style="font-size: 15px; font-weight: 500; color: #2C2A26;">@area.Name</span>
                    </label>
                }
            </div>

            @if (!Model.Any())
            {
                <div style="text-align: center; padding: 40px; color: #8A8578;">
                    <p>No research areas available yet. Please contact the Module Leader.</p>
                </div>
            }

            <div style="margin-top: 24px;">
                <button type="submit" style="padding: 10px 28px; background: #1A1F36; color: #C9A96E; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer;">
                    Save Expertise
                </button>
            </div>
        </form>
    </div>
</div>