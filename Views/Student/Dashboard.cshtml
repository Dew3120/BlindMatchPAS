@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Project Proposals</h2>
        <a asp-action="Create" class="btn btn-primary">+ New Proposal</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">You have not submitted any proposals yet.</div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Research Area</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var proposal in Model)
                {
                    <tr>
                        <td>@proposal.Title</td>
                        <td>@proposal.ResearchArea?.Name</td>
                        <td>@proposal.SubmittedAt.ToShortDateString()</td>
                        <td>
                            @switch (proposal.Status.ToString())
                            {
                                case "Pending":
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case "UnderReview":
                                    <span class="badge bg-primary">Under Review</span>
                                    break;
                                case "Matched":
                                    <span class="badge bg-success">Matched</span>
                                    break;
                                case "Withdrawn":
                                    <span class="badge bg-secondary">Withdrawn</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@proposal.Id" class="btn btn-sm btn-info">Details</a>
                            @if (proposal.Status.ToString() == "Pending")
                            {
                                <a asp-action="Edit" asp-route-id="@proposal.Id" class="btn btn-sm btn-warning">Edit</a>
                                <form asp-action="Withdraw" asp-route-id="@proposal.Id" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Withdraw this proposal?')">Withdraw</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>