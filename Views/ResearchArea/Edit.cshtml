@model BlindMatchPAS.Models.ResearchArea
@{
    ViewData["Title"] = "Edit Research Area";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div style="background: #F4F3F0; border-radius: 12px; padding: 24px; border: 0.5px solid #E0DDD6; margin-bottom: 24px;">
            <h4 style="color: #1A1F36; font-weight: 600; margin-bottom: 4px;">Edit Research Area</h4>
            <p style="color: #8A8578; font-size: 14px; margin-bottom: 0;">Update research area details</p>
        </div>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IsActive" />
            <div style="margin-bottom: 16px;">
                <label asp-for="Name" style="font-size: 14px; font-weight: 500; color: #2C2A26; display: block; margin-bottom: 6px;"></label>
                <input asp-for="Name" style="width: 100%; padding: 10px 14px; border: 0.5px solid #E0DDD6; border-radius: 8px; font-size: 14px; background: #FAFAF8;" />
                <span asp-validation-for="Name" style="color: #791F1F; font-size: 12px;"></span>
            </div>
            <div style="margin-bottom: 24px;">
                <label asp-for="Description" style="font-size: 14px; font-weight: 500; color: #2C2A26; display: block; margin-bottom: 6px;"></label>
                <textarea asp-for="Description" rows="3" style="width: 100%; padding: 10px 14px; border: 0.5px solid #E0DDD6; border-radius: 8px; font-size: 14px; background: #FAFAF8;"></textarea>
                <span asp-validation-for="Description" style="color: #791F1F; font-size: 12px;"></span>
            </div>
            <div style="display: flex; gap: 8px;">
                <button type="submit" style="padding: 10px 28px; background: #1A1F36; color: #C9A96E; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer;">Update Area</button>
                <a asp-action="Index" style="padding: 10px 28px; background: transparent; border: 0.5px solid #E0DDD6; border-radius: 8px; color: #8A8578; font-size: 14px; text-decoration: none;">Cancel</a>
            </div>
        </form>
    </div>
</div>