@model IEnumerable<BlindMatchPAS.Models.Match>
 
@{
    ViewData["Title"] = "Module Leader Dashboard";
}
 
@if (TempData["Success"] != null)
{
    <div class="alert alert-success"
         style="background: #E8F5ED;
                border: 1px solid #2D8A5E;
                color: #1B5E3F;">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger"
         style="background: #F5E0E0;
                border: 1px solid #C75050;
                color: #791F1F;">
        @TempData["Error"]
    </div>
}
 
<div style="margin-bottom: 24px;">
    <h4 style="color: #1A1F36;
               font-weight: 600;
               margin-bottom: 4px;">
        Module Leader Dashboard
    </h4>
    <p style="color: #8A8578;
              font-size: 14px;
              margin: 0;">
        Full system oversight
    </p>
</div>
 
<!-- Stats Cards -->
<div style="display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;">
    <div style="flex: 1;
                min-width: 140px;
                background: #FBF7F0;
                padding: 16px 20px;
                border-radius: 10px;
                border: 0.5px solid #E0DDD6;">
        <span style="font-size: 28px;
                     font-weight: 600;
                     color: #C9A96E;">
            @ViewBag.TotalProposals
        </span>
        <span style="font-size: 13px;
                     color: #8A8578;
                     display: block;">
            Total Proposals
        </span>
    </div>
    <div style="flex: 1;
                min-width: 140px;
                background: #FBF7F0;
                padding: 16px 20px;
                border-radius: 10px;
                border: 0.5px solid #E0DDD6;">
        <span style="font-size: 28px;
                     font-weight: 600;
                     color: #A68B4B;">
            @ViewBag.PendingProposals
        </span>
        <span style="font-size: 13px;
                     color: #8A8578;
                     display: block;">
            Pending
        </span>
    </div>
    <div style="flex: 1;
                min-width: 140px;
                background: #E8F5ED;
                padding: 16px 20px;
                border-radius: 10px;
                border: 0.5px solid #2D8A5E;">
        <span style="font-size: 28px;
                     font-weight: 600;
                     color: #1B5E3F;">
            @ViewBag.MatchedProposals
        </span>
        <span style="font-size: 13px;
                     color: #8A8578;
                     display: block;">
            Matched
        </span>
    </div>
    <div style="flex: 1;
                min-width: 140px;
                background: #E6F1FB;
                padding: 16px 20px;
                border-radius: 10px;
                border: 0.5px solid #185FA5;">
        <span style="font-size: 28px;
                     font-weight: 600;
                     color: #185FA5;">
            @ViewBag.TotalSupervisors
        </span>
        <span style="font-size: 13px;
                     color: #8A8578;
                     display: block;">
            Supervisors
        </span>
    </div>
</div>
 
<div style="display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;">
    <h5 style="color: #1A1F36;
               font-weight: 600;
               margin: 0;">
        Recent Matches
    </h5>
    <a asp-action="AllMatches"
       style="padding: 8px 20px;
              background: #1A1F36;
              color: #C9A96E;
              border-radius: 8px;
              text-decoration: none;
              font-size: 13px;
              font-weight: 500;">
        View All Matches
    </a>
</div>
 
@if (!Model.Any())
{
    <div style="text-align: center;
                padding: 60px;
                background: #F4F3F0;
                border-radius: 12px;
                border: 0.5px solid #E0DDD6;">
        <p style="color: #8A8578;
                  font-size: 16px;">
            No matches yet
        </p>
    </div>
}
else
{
    @foreach (var match in Model)
    {
        <div style="background: #FAFAF8;
                    border-radius: 10px;
                    padding: 20px;
                    border: 0.5px solid #E0DDD6;
                    margin-bottom: 12px;">
            <div style="display: flex;
                        justify-content: space-between;">
                <div>
                    <h6 style="color: #1A1F36;
                               font-weight: 600;">
                        @match.ProjectProposal.Title
                    </h6>
                    <span style="font-size: 13px;
                                 color: #8A8578;">
                        Student:
                        @match.ProjectProposal
                            .SubmittedBy.FullName
                        | Supervisor:
                        @match.Supervisor.FullName
                    </span>
                </div>
                <span style="font-size: 12px;
                             padding: 4px 14px;
                             border-radius: 20px;
                             font-weight: 500;
                             background: @(match.Status.ToString()
                                 == "Confirmed"
                                 ? "#E8F5ED" : "#FBF7F0");
                             color: @(match.Status.ToString()
                                 == "Confirmed"
                                 ? "#1B5E3F" : "#A68B4B");">
                    @match.Status
                </span>
            </div>
        </div>
    }
}
